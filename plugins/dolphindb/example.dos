// ============================================================
// AgentOS DolphinDB Plugin — 使用示例
// 在 DolphinDB 控制台或脚本中执行
// ============================================================

// ── 1. 加载插件 ──
loadPlugin("/path/to/plugins/AgentOS/PluginAgentOS.txt")

// ── 2. 初始化 AgentOS ──
// Mock 模式（无需 API key，用于开发测试）
agentOS::init()

// 或传入配置 JSON 连接真实 LLM
// agentOS::init('{"api_key":"sk-xxx","base_url":"https://api.openai.com/v1","model":"gpt-4o-mini"}')

// 或连接国内大模型（硅基流动/DeepSeek 等 OpenAI 兼容接口）
// agentOS::init('{"api_key":"sk-xxx","base_url":"https://api.siliconflow.cn/v1","model":"deepseek-chat"}')

// ── 3. 健康检查 ──
agentOS::health()
// 返回: {"healthy":true,"scheduler":true,"backend":true,...}

agentOS::status()
// 返回: "AgentOS | agents=0 | total_tokens=0 | total_requests=0"

// ── 4. 单轮对话 ──
agentOS::ask("什么是 DolphinDB？")
// 返回: 自然语言回答

// 带自定义 system prompt
agentOS::ask("分析这段数据的趋势", "你是一个金融数据分析师，用中文回答")

// ── 5. 流式对话（逐 token 实时输出）──
// 方式 A：传入回调函数，每个 token 实时 print 到客户端
agentOS::askStream("用三句话介绍时序数据库", , print)

// 方式 B：用自定义回调做更多处理
def onToken(token) {
    writeConsole(token)   // 实时输出到控制台
}
agentOS::askStream("什么是 DolphinDB？", , onToken)

// 方式 C：带 system prompt + 回调
agentOS::askStream("分析数据趋势", "你是金融分析师", print)

// 不传回调也可以，等全部生成完返回完整字符串（等同于 ask）
agentOS::askStream("用三句话介绍时序数据库")

// ── 5b. Web 流式输出（异步请求 + 轮询）──
// 适用于 DolphinDB Web UI / API 客户端
// 步骤 1: 发起异步请求，立即返回 requestId
rid = agentOS::askAsync("什么是 DolphinDB？")
// rid = "req_1"

// 步骤 2: 轮询获取增量内容（前端用 setInterval 每 100ms 调用一次）
result = agentOS::poll(rid)
// result 是 dict:
//   status  → "streaming" | "done" | "error"
//   delta   → 本次 poll 新增的 token（取走后清空）
//   content → 已生成的全部内容
//   done    → true/false
//   error   → 错误信息（无错时为空）

// 完整轮询示例：
rid = agentOS::askAsync("用三句话介绍时序数据库", "你是一个技术专家")
do {
    result = agentOS::poll(rid)
    if (result["delta"].size() > 0) {
        writeConsole(result["delta"])    // 追加显示
    }
    sleep(100)                           // 100ms 间隔
} while (!result["done"])

// 步骤 3（可选）: 取消或清理请求
agentOS::cancelAsync(rid)

// ── 6. 结构化对话（返回表格，含工具调用记录）──
result = agentOS::askTable("查询最新的市场数据")
select * from result
// 输出: role | content | tool_name | tool_args | tool_result

// 带配置
result = agentOS::askTable("帮我分析趋势", '{"system_prompt":"你是金融分析师","max_steps":5}')

// ── 7. 记忆系统 ──
// 存入记忆（content, [importance], [source]）
agentOS::remember("DolphinDB 是一款高性能时序数据库", 0.8)
agentOS::remember("AgentOS 支持 ReAct 循环", 0.7, "docs")
agentOS::remember("TSDB 适合处理金融 tick 数据", 0.9, "research")

// 从记忆中检索（query, [topK]）
recallResult = agentOS::recall("时序数据库有什么特点", 3)
select * from recallResult
// 输出: content | score | source | created_at

// ── 8. 知识图谱 ──
// 添加节点
agentOS::graphAddNode('{"id":"DolphinDB","type":"database","properties":{"category":"TSDB","language":"C++"}}')
agentOS::graphAddNode('{"id":"AgentOS","type":"framework","properties":{"category":"LLM Agent","language":"C++"}}')
agentOS::graphAddNode('{"id":"时序数据","type":"concept","content":"用于存储带时间戳的数据序列"}')

// 添加边
agentOS::graphAddEdge('{"source":"DolphinDB","target":"时序数据","relation":"处理","weight":0.95}')
agentOS::graphAddEdge('{"source":"AgentOS","target":"DolphinDB","relation":"集成","weight":0.8}')

// 查询图谱（nodeId, [maxResults]）
graphResult = agentOS::graphQuery("DolphinDB", 10)
select * from graphResult
// 输出: source | relation | target | weight

// ── 9. 注册自定义工具（DolphinDB 函数作为 Agent 工具）──
// 先定义 DolphinDB 函数
def queryLatestPrice(paramsJson) {
    params = parseExpr(paramsJson).eval()
    ticker = params["ticker"]
    return exec last price from loadTable("dfs://market", "trades") where symbol = ticker
}

// 注册为 AgentOS 工具
agentOS::registerTool(
    '{"id":"query_price","description":"查询最新股票价格","params":[{"name":"ticker","type":"string","description":"股票代码"}]}',
    "queryLatestPrice"
)

// ── 10. 持久 Agent（多轮对话）──
// 创建 Agent（返回 handle）
handle = agentOS::createAgent('{"name":"金融分析师","role_prompt":"你是一个专业的金融数据分析师","context_limit":16384}')

// 使用 Agent handle 进行多轮对话
result1 = agentOS::askTable("帮我分析今天的市场走势", "{}", handle)
result2 = agentOS::askTable("刚才的分析中，哪些因素最重要？", "{}", handle)

// 销毁 Agent
agentOS::destroyAgent(handle)

// ── 11. 知识库 RAG ──
// 创建知识库（可配置 embedding 模型、分块参数等）
kb = agentOS::createKB('{"embedding_model":"text-embedding-3-small","chunk_size":500,"chunk_overlap":50}')
// 也可以不传参数，使用默认配置
// kb = agentOS::createKB()

// 灌入文本文档
agentOS::ingest(kb, "ddb_intro", "DolphinDB 是一款高性能分布式时序数据库，支持流计算、内存计算和分布式计算。广泛应用于金融量化、物联网和工业互联网等场景。")
agentOS::ingest(kb, "ddb_sql", "DolphinDB 使用类 SQL 语法进行数据查询，支持 select、exec、pivot by、context by 等丰富的查询子句。还支持向量化计算和窗口函数。")
agentOS::ingest(kb, "ddb_stream", "DolphinDB 的流计算引擎支持实时数据处理，提供时间序列聚合引擎、横截面引擎、异常检测引擎等多种内置引擎。可以用于实时行情处理、实时风控和实时指标计算。")

// 批量灌入目录下的 .md/.txt 文件
// agentOS::ingestDir(kb, "/data/knowledge_docs/")

// 查看知识库状态
agentOS::kbInfo(kb)
// 返回 dict: {chunk_count: 6, doc_count: 3, embedding_model: "text-embedding-3-small", ...}

// 检索知识库
results = agentOS::search(kb, "DolphinDB 支持什么查询语法", 3)
select * from results
// 输出 table: doc_id | chunk_id | content | score | graph_context

// RAG 对话：自动检索 + LLM 回答
agentOS::askWithKB(kb, "DolphinDB 有哪些流计算引擎？")
// 返回：基于知识库内容生成的回答

// 带自定义 system prompt
agentOS::askWithKB(kb, "如何用 DolphinDB 做实时风控？", 5, "你是一个金融科技专家，用中文详细回答")

// 删除文档
agentOS::removeDoc(kb, "ddb_intro")

// 持久化知识库到磁盘
agentOS::saveKB(kb, "/data/my_kb/")

// 从磁盘加载（先创建空 KB，再 load）
kb2 = agentOS::createKB()
agentOS::loadKB(kb2, "/data/my_kb/")

// 销毁知识库
agentOS::destroyKB(kb)

// ── 12. 关闭 ──
agentOS::close()
