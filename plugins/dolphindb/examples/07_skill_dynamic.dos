// ============================================================
// 场景七：动态技能切换 — 一个 Agent 按需加载不同能力
// ============================================================
// 适合：通用助手根据任务自动获得对应能力
// 核心：registerSkill 定义能力包 → createAgent 指定初始技能 →
//       运行时 activateSkill/deactivateSkill 动态切换

loadPlugin(getHomeDir() + "/plugins/AgentOS/PluginAgentOS.txt")
agentOS::init("sk-xxx", model="deepseek-chat")

// ────────────────────────────────────
// 注册工具
// ────────────────────────────────────

def execSQL(paramsJson) {
    params = parseExpr(paramsJson).eval()
    sql = params["sql"]
    result = parseExpr(sql).eval()
    return result.toStdJson()
}

def sendAlert(paramsJson) {
    params = parseExpr(paramsJson).eval()
    // 模拟发送告警
    return '{"sent":true,"channel":"' + params["channel"] + '","message":"' + params["message"] + '"}'
}

def generateChart(paramsJson) {
    params = parseExpr(paramsJson).eval()
    // 模拟生成图表
    return '{"chart_url":"/tmp/chart_' + params["type"] + '.png","status":"generated"}'
}

agentOS::registerTool("exec_sql", "执行DolphinDB SQL", execSQL)
agentOS::registerTool("send_alert", "发送告警通知", sendAlert)
agentOS::registerTool("gen_chart", "生成数据图表", generateChart)

// ────────────────────────────────────
// 注册技能包
// ────────────────────────────────────

// 技能 1：数据查询
agentOS::registerSkill("数据查询",
    ["查询", "SQL", "select", "数据", "表", "统计"],
    prompt="你可以执行 DolphinDB SQL 来查询数据。使用 exec_sql 工具执行查询。",
    tools=["exec_sql"])

// 技能 2：监控告警
agentOS::registerSkill("监控告警",
    ["告警", "监控", "通知", "异常", "阈值"],
    prompt="你可以发送告警通知。支持邮件、钉钉、企业微信等渠道。",
    tools=["send_alert"])

// 技能 3：可视化
agentOS::registerSkill("数据可视化",
    ["图表", "可视化", "plot", "画图", "趋势图"],
    prompt="你可以生成数据图表，支持折线图、柱状图、饼图。",
    tools=["gen_chart"])

// ────────────────────────────────────
// 创建通用助手（初始不带任何技能）
// ────────────────────────────────────

assistant = agentOS::createAgent(
    name = "smart-assistant",
    prompt = "你是 DolphinDB 智能助手。根据用户需求，使用可用的工具完成任务。"
)

// ────────────────────────────────────
// 场景 A：用户要查数据 → 动态加载"数据查询"技能
// ────────────────────────────────────

print("=== 场景 A: 数据查询 ===")

// 检查匹配
matches = agentOS::matchSkills("帮我查下最近一周的交易量统计")
select * from matches
// → name: "数据查询", hitCount: 2

// 激活
agentOS::activateSkill(assistant, "数据查询")
print(agentOS::ask(assistant, "帮我查下最近一周每天的总交易量"))

// 查看状态
print(agentOS::info(assistant))
// skills: ["数据查询"]

// ────────────────────────────────────
// 场景 B：用户要画图 → 追加"可视化"技能
// ────────────────────────────────────

print("=== 场景 B: 追加可视化 ===")

agentOS::activateSkill(assistant, "数据可视化")
print(agentOS::ask(assistant, "把刚才的交易量数据画成趋势图"))

// 现在 assistant 同时有两个技能
print(agentOS::info(assistant))
// skills: ["数据查询", "数据可视化"]

// ────────────────────────────────────
// 场景 C：任务完成，去激活不需要的技能
// ────────────────────────────────────

print("=== 场景 C: 切换到监控模式 ===")

agentOS::deactivateSkill(assistant, "数据查询")
agentOS::deactivateSkill(assistant, "数据可视化")
agentOS::activateSkill(assistant, "监控告警")

print(agentOS::ask(assistant, "检测到 CPU 使用率超过 90%，发个钉钉告警"))

// ────────────────────────────────────
// 场景 D：运行时禁用/启用工具
// ────────────────────────────────────

print("=== 场景 D: 工具级控制 ===")

// 临时禁用 exec_sql（比如数据库维护期间）
agentOS::activateSkill(assistant, "数据查询")
agentOS::blockTool(assistant, "exec_sql", "数据库维护中")

print(agentOS::ask(assistant, "帮我查下数据"))
// agent 会告诉用户工具不可用

// 维护结束，恢复
agentOS::unblockTool(assistant, "exec_sql")
print(agentOS::ask(assistant, "现在可以查了，帮我看下数据"))

agentOS::destroy(assistant)
agentOS::close()
